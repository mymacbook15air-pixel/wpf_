<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadraticSolverMVVM.ViewModels"
        x:Class="QuadraticSolverMVVM.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Решение квадратных уравнений"
        Width="450"
        Height="380"
        MinWidth="400"
        MinHeight="350">
    
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                   Text="ax² + bx + c = 0" 
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>
        
        <Grid Grid.Row="1" Margin="0,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="a =" FontSize="14" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding A}" FontSize="14" Margin="5,0"/>
            <TextBlock Grid.Column="2" Text="x²" FontSize="14" VerticalAlignment="Center"/>
        </Grid>
        
        <Grid Grid.Row="2" Margin="0,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="b =" FontSize="14" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding B}" FontSize="14" Margin="5,0"/>
            <TextBlock Grid.Column="2" Text="x" FontSize="14" VerticalAlignment="Center"/>
        </Grid>
        
        <Grid Grid.Row="3" Margin="0,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="c =" FontSize="14" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding C}" FontSize="14" Margin="5,0"/>
            <TextBlock Grid.Column="2" Text="= 0" FontSize="14" VerticalAlignment="Center"/>
        </Grid>
        
        <Button Grid.Row="4" 
                Content="Решить"
                FontSize="14"
                Height="30"
                Width="100"
                Margin="0,15,0,10"
                HorizontalAlignment="Center"
                Command="{Binding SolveCommand}"/>
        
        <Border Grid.Row="5" 
                Background="#FF050505"
                CornerRadius="4"
                Padding="8">
            <StackPanel>
                <TextBlock Text="Результат:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Result}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Details}" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>