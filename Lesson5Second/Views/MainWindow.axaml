<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lesson5Second.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Lesson5Second.Views.MainWindow"
        Title="Управление продуктами (Тест)"
        Width="800"
        Height="500">
    
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Простой список вместо DataGrid -->
        <ListBox Grid.Row="0" 
                 ItemsSource="{Binding Products}" 
                 SelectedItem="{Binding SelectedProduct}"
                 Height="250">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Category}" Foreground="Gray"/>
                                <TextBlock Text="{Binding Price}" Foreground="Green"/>
                            </StackPanel>
                            <Button Grid.Column="1" 
                                    Content="Удалить"
                                    Command="{Binding $parent[Window].DataContext.DeleteCommand}"
                                    CommandParameter="{Binding}"
                                    Background="Red"
                                    Foreground="White"
                                    Margin="10,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" BorderBrush="Green" BorderThickness="2" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="ДОБАВЛЕНИЕ" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Название:" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding NewName}"/>
                    <TextBlock Text="Категория:" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding NewCategory}"/>
                    <TextBlock Text="Цена:" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding NewPrice}"/>
                    <Button Content="Добавить" Command="{Binding AddCommand}" Background="Green" Foreground="White" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" BorderBrush="Orange" BorderThickness="2" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="РЕДАКТИРОВАНИЕ" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Название:" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding SelectedProduct.Name}" IsEnabled="{Binding SelectedProduct}"/>
                    <TextBlock Text="Категория:" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding SelectedProduct.Category}" IsEnabled="{Binding SelectedProduct}"/>
                    <TextBlock Text="Цена:" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding SelectedProduct.Price}" IsEnabled="{Binding SelectedProduct}"/>
                    <Button Content="Сохранить" Command="{Binding SaveCommand}" Background="Orange" Foreground="White" Margin="0,10,0,0" IsEnabled="{Binding SelectedProduct}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
