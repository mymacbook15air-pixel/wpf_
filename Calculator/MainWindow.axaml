<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Calculator.MainWindow"
        Title="Калькулятор"
        Width="320"
        Height="460"
        MinWidth="320"
        MinHeight="460"
        Background="White">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Экран -->
        <Border Grid.Row="0" 
                Background="#F5F5F5" 
                CornerRadius="8"
                Margin="0,0,0,15"
                Padding="10">
            <TextBox x:Name="DisplayBox" 
                     FontSize="32" 
                     FontWeight="Bold"
                     TextAlignment="Right" 
                     IsReadOnly="True"
                     Text="0"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="#333333"/>
        </Border>
        
        <!-- Сетка кнопок -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Строка 1 -->
            <Button Grid.Row="0" Grid.Column="0" Content="7" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/" Click="Operator_Click" Margin="5" Background="#2196F3" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            
            <!-- Строка 2 -->
            <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" Click="Operator_Click" Margin="5" Background="#2196F3" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            
            <!-- Строка 3 -->
            <Button Grid.Row="2" Grid.Column="0" Content="1" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Click="Operator_Click" Margin="5" Background="#2196F3" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            
            <!-- Строка 4 -->
            <Button Grid.Row="3" Grid.Column="0" Content="0" Click="Number_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="18" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="3" Grid.Column="1" Content="." Click="Decimal_Click" Margin="5" Background="#EEEEEE" Foreground="#333333" FontSize="20" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="3" Grid.Column="2" Content="C" Click="Clear_Click" Margin="5" Background="#FF5722" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Click="Operator_Click" Margin="5" Background="#2196F3" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
            
            <!-- Строка 5 -->
            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Content="=" Click="Equals_Click" Margin="5" Background="#4CAF50" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" CornerRadius="6"/>
        </Grid>
    </Grid>
</Window>